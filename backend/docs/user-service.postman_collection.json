{
  "info": {
    "name": "UserService API",
    "description": "API для управления пользователями. Токены генерируются UserService, но проверяются API Gateway. UserService ожидает заголовки X-User-Id и X-Username для защищённых эндпоинтов.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Auth",
      "description": "Аутентификация и регистрация пользователей",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"john_doe\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": {
              "raw": "http://user-service:8003/api/auth/register",
              "host": ["user-service"],
              "port": "8003",
              "path": ["api", "auth", "register"]
            },
            "description": "Регистрация нового пользователя"
          },
          "response": [
            {
              "name": "Success",
              "code": 201,
              "body": "{\n  \"access_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n  \"token_type\": \"bearer\",\n  \"expires_in\": 3600,\n  \"user\": {\n    \"id\": 123456,\n    \"name\": \"john_doe\",\n    \"created_at\": \"2024-03-25T10:30:00Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"john_doe\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": {
              "raw": "http://user-service:8003/api/auth/login",
              "host": ["user-service"],
              "port": "8003",
              "path": ["api", "auth", "login"]
            },
            "description": "Вход в аккаунт"
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"access_token\": \"eyJhbGciOiJIUzI1NiIs...\",\n  \"token_type\": \"bearer\",\n  \"expires_in\": 3600,\n  \"user\": {\n    \"id\": 123456,\n    \"name\": \"john_doe\",\n    \"created_at\": \"2024-03-25T10:30:00Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://user-service:8003/api/auth/logout",
              "host": ["user-service"],
              "port": "8003",
              "path": ["api", "auth", "logout"]
            },
            "description": "Выход из аккаунта. Удаляет сессию из Redis по ключу session:{token}."
          },
          "response": [
            {
              "name": "Success",
              "code": 204
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "Управление профилем пользователя (через API Gateway)",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "123456",
                "type": "text"
              },
              {
                "key": "X-Username",
                "value": "john_doe",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://user-service:8003/api/users/me",
              "host": ["user-service"],
              "port": "8003",
              "path": ["api", "users", "me"]
            },
            "description": "Получить информацию о текущем пользователе"
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"id\": 123456,\n  \"name\": \"john_doe\",\n  \"created_at\": \"2024-03-25T10:30:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Update User Name",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-User-Id",
                "value": "123456",
                "type": "text"
              },
              {
                "key": "X-Username",
                "value": "john_doe",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"new_username\"\n}"
            },
            "url": {
              "raw": "http://user-service:8003/api/users/me",
              "host": ["user-service"],
              "port": "8003",
              "path": ["api", "users", "me"]
            },
            "description": "Обновить имя пользователя"
          },
          "response": [
            {
              "name": "Success",
              "code": 200,
              "body": "{\n  \"id\": 123456,\n  \"name\": \"new_username\",\n  \"created_at\": \"2024-03-25T10:30:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-User-Id",
                "value": "123456",
                "type": "text"
              },
              {
                "key": "X-Username",
                "value": "john_doe",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"securepass123\",\n  \"new_password\": \"newpass456\"\n}"
            },
            "url": {
              "raw": "http://user-service:8003/api/users/me/password",
              "host": ["user-service"],
              "port": "8003",
              "path": ["api", "users", "me", "password"]
            },
            "description": "Сменить пароль"
          },
          "response": [
            {
              "name": "Success",
              "code": 204
            }
          ]
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://user-service:8003/api/users/me",
              "host": ["user-service"],
              "port": "8003",
              "path": ["api", "users", "me"]
            },
            "description": "Удалить аккаунт пользователя"
          },
          "response": [
            {
              "name": "Success",
              "code": 204
            },
            {
              "name": "Unauthorized",
              "code": 401,
              "body": "{\n  \"detail\": \"Invalid or expired token\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "description": "Проверка работоспособности",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://user-service:8003/health",
              "host": ["user-service"],
              "port": "8003",
              "path": ["health"]
            },
            "description": "Проверка работы сервиса"
          },
          "response": [
            {
              "name": "Healthy",
              "code": 200,
              "body": "{\n  \"status\": \"healthy\",\n  \"service\": \"user-service\",\n  \"redis\": \"connected\"\n}"
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ]
}