# PostgreSQL
POSTGRES_DB=testdb
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Cassandra
CASSANDRA_PORT=9042

# Kafka
KAFKA_UI_PORT=9091
KAFKA_EXTERNAL_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_INTERNAL_PORT=9094

# API Gateway
GATEWAY_PORT=8080

# User Service
USER_SERVICE_PORT=8001
SECRET_KEY=your-shared-secret-key-with-api-gateway
JWT_ALGORITHM=HS256

# NewsFetcherService
KAFKA_BOOTSTRAP_SERVERS=kafka:9094
KAFKA_NEWS_TOPIC_NAME=news-topic
FETCHING_INTERVAL_MS=3600000
GNEWS_APIKEY=<api_key_here>
